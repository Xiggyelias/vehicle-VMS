Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^auth/google/callback/?$ google_auth.php [L,QSA]
</IfModule>

<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(composer\.(json|lock)|phpunit\.xml)$">
    Require all denied
</FilesMatch>
